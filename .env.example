# Frontend API Keys (VITE_ prefix - accessible in React)

# AI Providers (OpenRouter recommended - has free models)
VITE_OPENROUTER_API_KEY=your_openrouter_api_key_here
VITE_GROQ_API_KEY=your_groq_api_key_here
VITE_HF_TOKEN=your_huggingface_token_here

# Creator Data APIs
VITE_YOUTUBE_API_KEY=your_youtube_data_api_key_here
# Needed for Instagram oEmbed (Meta app access token)
VITE_INSTAGRAM_APP_ACCESS_TOKEN=your_instagram_app_access_token_here

# Optional: Gemini (not used by default)
# VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Stripe Payment Integration
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# Supabase (client-safe values only)
VITE_SUPABASE_URL=https://your_project_ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ============================================
# Backend API Keys (NO VITE_ prefix - server only)
# These should be set in Vercel environment variables
# ============================================

# Stripe Secret Keys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Supabase server-side keys (for webhook server-side operations)
SUPABASE_URL=https://your_project_ref.supabase.co
SUPABASE_PROJECT_ID=your_project_ref
SUPABASE_SECRET_KEY=your_supabase_service_role_or_secret_key

# Brevo Email Delivery
# API key mode (xkeysib-...)
BREVO_API_KEY=your_brevo_api_key_here
BREVO_SENDER_EMAIL=verified_sender@yourdomain.com
BREVO_SENDER_NAME=CollabFree

# SMTP mode (xsmtpsib-... key/password)
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=your_brevo_smtp_username
BREVO_SMTP_PASS=your_brevo_smtp_password_or_xsmtpsib_key
# Optional: true when using port 465
BREVO_SMTP_SECURE=false
